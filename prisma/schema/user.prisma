model User {
    id        String     @id @default(uuid())
    name      String     @db.VarChar(255)
    email     String     @unique
    password  String
    phone     String     @unique
    avatar    String
    role      Role       @default(TENANT)
    status    UserStatus
    createdAt DateTime   @default(now())
    updatedAt DateTime   @updatedAt

    property Property[]

    @@map("users")
}
