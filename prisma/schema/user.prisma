model User {
  id       String     @id @default(uuid())
  name     String     @db.VarChar(255)
  email    String     @unique
  password String
  phone    String?    @unique
  avatar   String?
  role     Role       @default(TENANT)
  status   UserStatus @default(UNBAN)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  property      Property[]
  rentalRequest RentalRequest[]
  reviews       Review[]
  payment       Payment[]

  @@map("users")
}
